{
  "name": "max-editor",
  "displayName": "MaxEditor",
  "description": "Maximize the editor by hiding all side panels, then restore them with one click.",
  "version": "0.1.1",
  "publisher": "cgaspard",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/cgaspard/maxeditor.git"
  },
  "bugs": {
    "url": "https://github.com/cgaspard/maxeditor/issues"
  },
  "homepage": "https://github.com/cgaspard/maxeditor#readme",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "maximize",
    "editor",
    "zen",
    "focus",
    "panels"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "maxeditor.toggleMaximize",
        "title": "Max Editor: Toggle Maximize Editor",
        "icon": "$(screen-full)"
      }
    ],
    "keybindings": [
      {
        "command": "maxeditor.toggleMaximize",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "maxeditor.toggleMaximize",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "compile:test": "npm run check-types && node esbuild.js --tests",
    "check-types": "tsc --noEmit",
    "watch": "node esbuild.js --watch",
    "test": "npm run compile:test && node dist/test/runTests.js",
    "test:unit": "npm run compile:test && node -e \"const m=new(require('mocha'))({ui:'tdd',color:true});m.addFile('./dist/test/suite/sqlite-reader.test.js');m.run(f=>process.exit(f>0?1:0));\"",
    "package": "npm run check-types && node esbuild.js --production",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.104.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.3.0"
  }
}
